{
  "name": "budgetbrain",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install:all": "npm --prefix server install && npm --prefix client install",
    "client:dev": "npm --prefix client run dev",
    "server:dev": "npm --prefix server run dev",
    "db:deploy": "npm --prefix server run db:deploy",
    "db:migrate": "npm --prefix server run db:migrate",
    "db:seed": "npm --prefix server run db:seed",
    "client:build": "npm --prefix client run build",
    "client:test": "npm --prefix client test",
    "server:test": "npm --prefix server test",
    "test": "npm --prefix server test && npm --prefix client test",
    "build": "npm --prefix client run build"
  }
}
